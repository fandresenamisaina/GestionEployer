<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" styleClass="fond-formulaire" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.gestionemployer.controller.EmployeFormController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0"/>
    </padding>

    <Label styleClass="titre-page" text="Fiche employe"/>

    <GridPane hgap="12.0" vgap="10.0">
        <columnConstraints>
            <ColumnConstraints prefWidth="140.0"/>
            <ColumnConstraints prefWidth="220.0"/>
            <ColumnConstraints prefWidth="140.0"/>
            <ColumnConstraints prefWidth="220.0"/>
        </columnConstraints>

        <Label text="Nom" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="champNom" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Label text="Prenom" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
        <TextField fx:id="champPrenom" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

        <Label text="Adresse" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="champAdresse" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        <Label text="Telephone" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
        <TextField fx:id="champTelephone" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

        <Label text="Email" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="champEmail" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        <Label text="Poste" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
        <TextField fx:id="champPoste" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

        <Label text="Departement" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="champDepartement" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        <Label text="Date d'embauche" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
        <DatePicker fx:id="champDateEmbauche" GridPane.rowIndex="3" GridPane.columnIndex="3"/>

        <Label text="Salaire mensuel" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="champSalaire" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
        <Label text="Statut" GridPane.rowIndex="4" GridPane.columnIndex="2"/>
        <ComboBox fx:id="champStatut" GridPane.rowIndex="4" GridPane.columnIndex="3" maxWidth="Infinity"/>

        <Label text="Moyen de paiement" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <ComboBox fx:id="champModePaiement" GridPane.rowIndex="5" GridPane.columnIndex="1" maxWidth="Infinity"/>
        <Label text="Banque" GridPane.rowIndex="5" GridPane.columnIndex="2"/>
        <TextField fx:id="champBanque" GridPane.rowIndex="5" GridPane.columnIndex="3"/>

        <Label text="N° compte / carte" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <TextField fx:id="champNumeroCompte" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
    </GridPane>

    <Label fx:id="labelErreur" styleClass="erreur"/>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button onAction="#onAnnulerClick" styleClass="bouton-secondaire" text="Annuler"/>
        <Button onAction="#onEnregistrerClick" styleClass="bouton-principal" text="Enregistrer"/>
    </HBox>
</VBox>
