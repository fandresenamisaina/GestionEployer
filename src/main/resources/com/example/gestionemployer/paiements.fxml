<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16.0" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.gestionemployer.controller.PaiementsController">
    <padding>
        <Insets bottom="24.0" left="28.0" right="28.0" top="24.0"/>
    </padding>

    <Label styleClass="titre-page" text="Paiements des salaires"/>

    <HBox spacing="14.0" alignment="CENTER_LEFT">
        <Label text="Solde entreprise :"/>
        <Label fx:id="labelSolde" styleClass="carte-stat-valeur" text="0"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button onAction="#onGenererRecuClick" styleClass="bouton-secondaire" text="Generer un recu"/>
        <Button onAction="#onPaiementMensuelClick" styleClass="bouton-principal" text="Effectuer le paiement du mois"/>
    </HBox>

    <TableView fx:id="tablePaiements" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="Reference interne" prefWidth="110.0"/>
            <TableColumn fx:id="colEmploye" text="Employe" prefWidth="180.0"/>
            <TableColumn fx:id="colDate" text="Date" prefWidth="100.0"/>
            <TableColumn fx:id="colMontant" text="Montant" prefWidth="110.0"/>
            <TableColumn fx:id="colStatut" text="Statut" prefWidth="180.0"/>
            <TableColumn fx:id="colReference" text="Reference virement" prefWidth="140.0"/>
        </columns>
    </TableView>
</VBox>
