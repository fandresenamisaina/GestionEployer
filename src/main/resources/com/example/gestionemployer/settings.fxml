<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16.0" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.gestionemployer.controller.SettingsController">
    <padding>
        <Insets bottom="24.0" left="28.0" right="28.0" top="24.0"/>
    </padding>

    <Label styleClass="titre-page" text="Parametres de l'entreprise"/>

    <GridPane hgap="12.0" vgap="10.0">
        <columnConstraints>
            <ColumnConstraints prefWidth="160.0"/>
            <ColumnConstraints prefWidth="260.0"/>
            <ColumnConstraints prefWidth="160.0"/>
            <ColumnConstraints prefWidth="260.0"/>
        </columnConstraints>

        <Label text="Nom entreprise" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="champNom" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Label text="Responsable" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
        <TextField fx:id="champResponsable" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

        <Label text="Adresse" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="champAdresse" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        <Label text="Telephone" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
        <TextField fx:id="champTelephone" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

        <Label text="Email" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="champEmail" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        <Label text="Nom de la banque" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
        <TextField fx:id="champNomBanque" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

        <Label text="N° compte entreprise" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="champNumeroCompte" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        <Label text="Solde disponible" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
        <TextField fx:id="champSolde" GridPane.rowIndex="3" GridPane.columnIndex="3"/>

        <Label text="N° carte bancaire" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="champNumeroCarteBancaire" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Nom d'utilisateur" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextField fx:id="champNomUtilisateur" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
        <Label text="Mot de passe" GridPane.rowIndex="5" GridPane.columnIndex="2"/>
        <TextField fx:id="champMotDePasse" GridPane.rowIndex="5" GridPane.columnIndex="3"/>
    </GridPane>

    <Label fx:id="labelMessage" styleClass="erreur"/>

    <HBox alignment="CENTER_RIGHT">
        <Button onAction="#onEnregistrerClick" styleClass="bouton-principal" text="Enregistrer les parametres"/>
    </HBox>
</VBox>
