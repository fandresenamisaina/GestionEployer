<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="14.0" styleClass="login-pane" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.gestionemployer.controller.LoginController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <Label styleClass="titre" text="Gestion des employes"/>
    <Label styleClass="sous-titre" text="Connectez-vous pour continuer"/>

    <VBox spacing="6.0">
        <Label text="Nom d'utilisateur"/>
        <TextField fx:id="champUtilisation" promptText="admin"/>
    </VBox>

    <VBox spacing="6.0">
        <Label text="Mot de passe"/>
        <PasswordField fx:id="champMotDePasse" promptText="mot de passe"/>
    </VBox>

    <Label fx:id="labeler" styleClass="erreur"/>

    <Button defaultButton="true" maxWidth="Infinity" onAction="#onLoginClick" styleClass="bouton-principal" text="Se connecter"/>
</VBox>
